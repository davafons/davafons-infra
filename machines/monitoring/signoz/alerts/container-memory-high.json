{
  "alert": "ContainerMemoryHigh",
  "alertType": "METRIC_BASED_ALERT",
  "ruleType": "threshold_rule",
  "version": "v5",
  "frequency": "1m",
  "evalWindow": "5m",
  "disabled": false,
  "labels": { "severity": "warning" },
  "annotations": {
    "description": "Container {{ .Labels.container_name }} on {{ .Labels.host_name }} is using more than 80% of its memory limit"
  },
  "preferredChannels": ["discord"],
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "graph",
      "unit": "percent",
      "builderQueries": {
        "A": {
          "queryName": "A",
          "dataSource": "metrics",
          "aggregateOperator": "avg",
          "aggregateAttribute": {
            "key": "container.memory.percent",
            "type": "Gauge",
            "dataType": "float64"
          },
          "groupBy": [
            { "key": "host.name", "type": "resource", "dataType": "string" },
            { "key": "container.name", "type": "resource", "dataType": "string" }
          ],
          "filters": { "op": "AND", "items": [] },
          "expression": "A",
          "disabled": false
        }
      }
    },
    "op": "1",
    "target": 80,
    "matchType": "1",
    "selectedQueryName": "A"
  }
}
