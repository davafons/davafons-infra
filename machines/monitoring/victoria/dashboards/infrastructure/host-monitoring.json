          "expr": "rate(system_disk_operation_time_seconds_total{host_name=~\"${host:regex}\", device=~\"${diskdevice:regex}\"}[$__rate_interval]) / rate(system_disk_operations_total{host_name=~\"${host:regex}\", device=~\"${diskdevice:regex}\"}[$__rate_interval])",
