          "expr": "system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"free\"}",
          "legendFormat": "{{ host_name }} - free",
          "refId": "D"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
