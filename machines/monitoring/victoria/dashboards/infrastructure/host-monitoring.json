          "expr": "rate(system_network_packets_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\", direction=\"transmit\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }} {{ device }} transmit",
          "refId": "B"
        }
      ],
