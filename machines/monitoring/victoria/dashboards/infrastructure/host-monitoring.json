{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 200,
      "title": "Alert Status",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.6
              },
              {
                "color": "red",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 201,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "1 - avg by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "CPU (alert > 80%)",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 202,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "(sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"used\"}) / sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\"})) * 100",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "Memory % (alert > 80%)",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 5368709120
              },
              {
                "color": "green",
                "value": 10737418240
              }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 203,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "system_filesystem_usage_bytes{host_name=~\"${host:regex}\", mountpoint=\"/\", state=\"free\"}",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "Disk Free / (alert < 5GB)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 101,
      "title": "CPU",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 10,
      "targets": [
        {
          "expr": "1 - avg by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "description": "Stacked CPU time by state per host",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": {
              "mode": "normal"
            }
          },
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 11,
      "targets": [
        {
          "expr": "avg by (host_name, state) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state!=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }} - {{ state }}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage by State",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 102,
      "title": "Load Average",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "id": 12,
      "targets": [
        {
          "expr": "system_cpu_load_average_1m{host_name=~\"${host:regex}\"}",
          "legendFormat": "{{ host_name }} - 1m",
          "refId": "A"
        },
        {
          "expr": "system_cpu_load_average_5m{host_name=~\"${host:regex}\"}",
          "legendFormat": "{{ host_name }} - 5m",
          "refId": "B"
        },
        {
          "expr": "system_cpu_load_average_15m{host_name=~\"${host:regex}\"}",
          "legendFormat": "{{ host_name }} - 15m",
          "refId": "C"
        }
      ],
      "title": "Load Average",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "id": 13,
      "targets": [
        {
          "expr": "system_processes_count{host_name=~\"${host:regex}\"}",
          "legendFormat": "{{ host_name }} - {{ status }}",
          "refId": "A"
        },
        {
          "expr": "rate(system_processes_created_total{host_name=~\"${host:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }} - forks/s",
          "refId": "B"
        }
      ],
      "title": "Processes",
      "type": "timeseries"
    },
    {
      "collapsed": false,
