{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Trace Volume",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "count(count by (service_name) (traces_span_metrics_duration_milliseconds_count{deployment_environment=~\"${environment:regex}\"}))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Active Services",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_duration_milliseconds_count{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Total Server Span Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_milliseconds_total{status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Error Span Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Overall P95 Latency",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_duration_milliseconds_count{deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Span Volume by Service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (span_kind) (rate(traces_span_metrics_duration_milliseconds_count{deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ span_kind }}",
          "refId": "A"
        }
      ],
      "title": "Span Volume by Kind",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 20,
      "title": "Error Analysis",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 21,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_milliseconds_total{status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Error Spans by Service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 22,
      "targets": [
        {
          "expr": "sum by (service_name, span_name) (rate(traces_span_metrics_calls_milliseconds_total{status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "{{ service_name }} {{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Error Spans by Endpoint",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 30,
      "title": "Latency Analysis",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "id": 31,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p99",
          "refId": "C"
        }
      ],
      "title": "Server Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "id": 32,
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, service_name, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))))",
          "legendFormat": "{{ service_name }} {{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Slowest Endpoints P95 (Top 10)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "id": 33,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_CLIENT\", span_name=~\"pg..*\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "DB Client Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "id": 34,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_CLIENT\", span_name!~\"pg..*|pg-pool\\..*\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Outbound HTTP Client Latency P95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "id": 40,
      "title": "Service Dependencies",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "id": 41,
      "targets": [
        {
          "expr": "sum by (service_name, span_kind) (rate(traces_span_metrics_duration_milliseconds_count{deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }} ({{ span_kind }})",
          "refId": "A"
        }
      ],
      "title": "Span Rate by Service & Kind",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "id": 42,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_bytes_total{deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Trace Payload Volume by Service",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "tags": [
    "infrastructure",
    "traces"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "VictoriaMetrics (Prometheus)",
          "value": "victoriametrics-prom"
        },
        "hide": 2,
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "uid": "${datasource}"
        },
        "definition": "label_values(traces_span_metrics_duration_milliseconds_count, deployment_environment)",
        "hide": 0,
        "includeAll": true,
        "label": "Environment",
        "multi": true,
        "name": "environment",
        "query": "label_values(traces_span_metrics_duration_milliseconds_count, deployment_environment)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Telemetry Ingestion",
  "uid": "telemetry-ingestion"
}