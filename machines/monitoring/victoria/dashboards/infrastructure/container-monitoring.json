{
  "uid": "container-monitoring",
  "title": "Container Monitoring",
  "tags": [
    "infrastructure",
    "containers"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "VictoriaMetrics (Prometheus)",
          "value": "victoriametrics-prom"
        },
        "hide": 2
      },
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "uid": "${datasource}"
        },
        "query": "label_values(container_cpu_utilization_ratio, host_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "uid": "${datasource}"
        },
        "query": "label_values(container_cpu_utilization_ratio{host_name=~\"${host:regex}\"}, container_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "count(count by (container_name) (container_cpu_utilization_ratio{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}))",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "title": "Container Count",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent",
          "decimals": 1
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(container_cpu_utilization_ratio{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}) by (host_name)",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "Total CPU per Host",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5368709120
              },
              {
                "color": "red",
                "value": 8589934592
              }
            ]
          },
          "unit": "bytes",
          "decimals": 1
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_usage_total_bytes{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}) by (host_name)",
          "legendFormat": "{{ host_name }}",
          "refId": "A"
        }
      ],
      "title": "Total Memory per Host",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 10,
      "title": "CPU",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "min": 0,
          "unit": "percent",
          "decimals": 1
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 11,
      "targets": [
        {
          "expr": "container_cpu_utilization_ratio{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}",
          "legendFormat": "{{ host_name }}/{{ container_name }}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage per Container",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent",
          "decimals": 1
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 12,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        }
      ],
      "targets": [
        {
          "expr": "sort_desc(container_cpu_utilization_ratio{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}) ",
          "legendFormat": "{{ container_name }}",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Current CPU per Container",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 20,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "min": 0,
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 21,
      "targets": [
        {
          "expr": "container_memory_usage_total_bytes{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}",
          "legendFormat": "{{ host_name }}/{{ container_name }}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage per Container",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "container_name"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Container"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #usage"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Usage"
              },
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #limit"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Limit"
              },
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #percent"
            },
            "properties": [
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "displayName",
                "value": "%"
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 60
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 22,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "%",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true
            },
            "indexByName": {
              "container_name": 0,
              "Value #usage": 1,
              "Value #limit": 2,
              "Value #percent": 3
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "max by (container_name) (container_memory_usage_total_bytes{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"})",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "usage"
        },
        {
          "expr": "max by (container_name) (container_memory_usage_limit_bytes{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"})",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "limit"
        },
        {
          "expr": "max by (container_name) (container_memory_percent_ratio{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"})",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "percent"
        }
      ],
      "title": "Memory per Container",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 30,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 31,
      "targets": [
        {
          "expr": "rate(container_network_io_usage_rx_bytes_total{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }}/{{ container_name }}",
          "refId": "A"
        }
      ],
      "title": "Network RX (Receive)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 32,
      "targets": [
        {
          "expr": "rate(container_network_io_usage_tx_bytes_total{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }}/{{ container_name }}",
          "refId": "A"
        }
      ],
      "title": "Network TX (Transmit)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "pps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "id": 33,
      "targets": [
        {
          "expr": "rate(container_network_io_usage_rx_dropped_total{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }}/{{ container_name }} RX drops",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_io_usage_tx_dropped_total{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }}/{{ container_name }} TX drops",
          "refId": "B"
        }
      ],
      "title": "Network Dropped Packets",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "id": 40,
      "title": "Disk I/O",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 45
      },
      "id": 41,
      "targets": [
        {
          "expr": "rate(container_blockio_io_service_bytes_recursive_total{host_name=~\"${host:regex}\", container_name=~\"${container:regex}\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }}/{{ container_name }}",
          "refId": "A"
        }
      ],
      "title": "Block I/O per Container",
      "type": "timeseries"
    }
  ]
}
