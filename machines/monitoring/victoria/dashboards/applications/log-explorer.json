{
  "panels": [
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ERROR"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "WARN"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "INFO"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "DEBUG"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Unspecified"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "semi-dark-purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "editorMode": "code",
          "expr": "{service.name=~\"${service}\", host.name=~\"${host}\", deployment.environment=~\"${environment}\"} severity:~\"${severity:regex}\" ${search} | stats by (severity) count() logs",
          "legendFormat": "{{ severity }}",
          "queryType": "statsRange",
          "refId": "A"
        }
      ],
      "title": "Log Volume",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "{service.name=~\"${service}\", host.name=~\"${host}\", deployment.environment=~\"${environment}\"} severity:~\"${severity}\" ${search}",
          "maxLines": 500,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "tags": [
    "infrastructure",
    "logs"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": ".+"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".+"
          },
          {
            "selected": false,
            "text": "production",
            "value": "production"
          },
          {
            "selected": false,
            "text": "infrastructure",
            "value": "infrastructure"
          },
          {
            "selected": false,
            "text": "development",
            "value": "development"
          }
        ],
        "query": "All : .+,production,infrastructure,development",
        "type": "custom"
      },
      {
        "current": {
          "text": "All",
          "value": ".+"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "multi": false,
        "name": "service",
        "query": "All : .+,kamal-proxy,nadeshiko-frontend-prod-web-prod,nadeshiko-backend-prod-web-prod,nadeshiko-backend-prod-postgres,nadeshiko-frontend-dev-web-dev,nadeshiko-backend-dev-web-dev,grafana,victorialogs,syncthing,homeassistant,restic-backup",
        "type": "custom"
      },
      {
        "current": {
          "text": "All",
          "value": ".+"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Host",
        "multi": false,
        "name": "host",
        "query": "All : .+,nadeshiko,monitoring,inari,watchtower,qtower",
        "type": "custom"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Severity",
        "multi": true,
        "name": "severity",
        "query": "ERROR,WARN,INFO,DEBUG,Unspecified",
        "type": "custom"
      },
      {
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Log Explorer",
  "uid": "log-explorer"
}
