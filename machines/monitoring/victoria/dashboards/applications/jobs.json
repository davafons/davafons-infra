{
  "uid": "jobs",
  "title": "Job Queues",
  "tags": [
    "applications",
    "pgboss",
    "jobs"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "VictoriaMetrics (Prometheus)",
          "value": "victoriametrics-prom"
        },
        "hide": 2
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(pgboss_job_count_total, deployment_environment)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": { "text": "production", "value": "production" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Queue Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total Failed Jobs",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(pgboss_queue_failed{deployment_environment=\"${environment}\"}) or vector(0)",
          "legendFormat": "failed",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Queued",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(pgboss_queue_size{deployment_environment=\"${environment}\", pgboss_state=\"queued\"}) or vector(0)",
          "legendFormat": "queued",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Active",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(pgboss_queue_size{deployment_environment=\"${environment}\", pgboss_state=\"active\"}) or vector(0)",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Job Throughput",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(pgboss_job_count_total{deployment_environment=\"${environment}\"}[$__rate_interval]))",
          "legendFormat": "jobs/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Queue Depth Over Time",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Queued Jobs by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pgboss_queue_size{deployment_environment=\"${environment}\", pgboss_state=\"queued\"}",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active Jobs by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pgboss_queue_size{deployment_environment=\"${environment}\", pgboss_state=\"active\"}",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failed Jobs by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pgboss_queue_failed{deployment_environment=\"${environment}\"} > 0",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deferred Jobs by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pgboss_queue_size{deployment_environment=\"${environment}\", pgboss_state=\"deferred\"}",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Job Processing",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Job Throughput by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (pgboss_queue) (rate(pgboss_job_count_total{deployment_environment=\"${environment}\", pgboss_status=\"completed\"}[$__rate_interval]))",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Failure Rate by Queue",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (pgboss_queue) (rate(pgboss_job_count_total{deployment_environment=\"${environment}\", pgboss_status=\"failed\"}[$__rate_interval])) > 0",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Processing Duration (p95)",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pgboss_queue) (rate(pgboss_job_duration_seconds_bucket{deployment_environment=\"${environment}\"}[$__rate_interval])))",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Processing Duration (p50)",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, pgboss_queue) (rate(pgboss_job_duration_seconds_bucket{deployment_environment=\"${environment}\"}[$__rate_interval])))",
          "legendFormat": "{{pgboss_queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Connection Pool",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "PG Connection Pool",
      "description": "Application database connection pool usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "db_client_connection_max{deployment_environment=\"${environment}\", service_name=~\"nadeshiko-backend-.*\", scope_name=\"nadeshiko-backend\"}",
          "legendFormat": "max",
          "refId": "A"
        },
        {
          "expr": "db_client_connection_count{deployment_environment=\"${environment}\", service_name=~\"nadeshiko-backend-.*\", db_client_connection_state=\"used\", scope_name=\"nadeshiko-backend\"}",
          "legendFormat": "used",
          "refId": "B"
        },
        {
          "expr": "db_client_connection_count{deployment_environment=\"${environment}\", service_name=~\"nadeshiko-backend-.*\", db_client_connection_state=\"idle\", scope_name=\"nadeshiko-backend\"}",
          "legendFormat": "idle",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PG Connection Pool - Pending Requests",
      "description": "Requests waiting for a connection from the pool. Non-zero values indicate pool exhaustion.",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "db_client_connection_pending_requests{deployment_environment=\"${environment}\", service_name=~\"nadeshiko-backend-.*\", scope_name=\"nadeshiko-backend\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
