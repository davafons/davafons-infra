          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "elasticsearch_index_segments_count{host_name=~\"${host:regex}\", elasticsearch_index_name=~\"${index:regex}\", elasticsearch_index_name!=\"_all\", aggregation=\"primary_shards\"}",
          "legendFormat": "{{ elasticsearch_index_name }}"
        }
      ]
    }
  ]
}
