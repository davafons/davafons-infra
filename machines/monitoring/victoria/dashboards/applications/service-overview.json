{
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_duration_milliseconds_count{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Service",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 6 },
      "id": 3,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) / sum by (service_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Service",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 11 },
      "id": 4,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Service",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 10,
      "title": "Request Rate",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 11,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_duration_milliseconds_count{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 12,
      "targets": [
        {
          "expr": "sum by (status_code) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ status_code }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 20,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 21,
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) / sum by (service_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ],
      "title": "Error Rate % by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 22,
      "targets": [
        {
          "expr": "sum by (service_name, span_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "{{ service_name }} {{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Errors by Service & Endpoint",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 30,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 31,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "{{ service_name }} p99",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 32,
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, span_name, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))))",
          "legendFormat": "{{ service_name }} {{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Endpoint (Top 10 Slowest)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 40,
      "title": "Throughput by Endpoint",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
      "id": 41,
      "options": {
        "footer": { "enablePagination": true },
        "showHeader": true,
        "sortBy": [{ "displayName": "Rate (req/s)", "desc": true }]
      },
      "targets": [
        {
          "expr": "sum by (service_name, span_name) (rate(traces_span_metrics_duration_milliseconds_count{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "",
          "refId": "rate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (service_name, span_name) (rate(traces_span_metrics_calls_milliseconds_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "",
          "refId": "errors",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])))",
          "legendFormat": "",
          "refId": "p95",
          "format": "table",
          "instant": true
        }
      ],
      "title": "Endpoint Table (Rate, Errors, P95)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "service_name": "Service",
              "span_name": "Endpoint",
              "Value #rate": "Rate (req/s)",
              "Value #errors": "Errors (req/s)",
              "Value #p95": "P95 (ms)"
            },
            "excludeByName": { "Time": true }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 50,
      "title": "Database Operations",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "id": 51,
      "targets": [
        {
          "expr": "sum by (span_name) (rate(traces_span_metrics_duration_milliseconds_count{span_kind=\"SPAN_KIND_CLIENT\", span_name=~\"pg.query.*\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval])) > 0",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "DB Query Rate (Top Queries)",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "id": 52,
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_CLIENT\", span_name=~\"pg..*\", deployment_environment=~\"${environment:regex}\"}[$__rate_interval]))))",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "DB Query P95 Latency (Top 10 Slowest)",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "tags": ["applications", "overview"],
  "annotations": {
    "list": [
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "iconColor": "rgba(150, 100, 255, 1)",
        "name": "Deploys",
        "type": "tags",
        "tags": ["deploy"]
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": { "text": "VictoriaMetrics (Prometheus)", "value": "victoriametrics-prom" },
        "hide": 2,
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "uid": "${datasource}" },
        "definition": "label_values(traces_span_metrics_duration_milliseconds_count, deployment_environment)",
        "hide": 0,
        "includeAll": true,
        "label": "Environment",
        "multi": true,
        "name": "environment",
        "query": "label_values(traces_span_metrics_duration_milliseconds_count, deployment_environment)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Service Overview",
  "uid": "service-overview"
}
