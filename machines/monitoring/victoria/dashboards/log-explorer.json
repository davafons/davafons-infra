{
  "uid": "log-explorer",
  "title": "Log Explorer",
  "tags": ["infrastructure", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "editable": false,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "label": "Environment",
        "query": "All : .+,production,infrastructure,development",
        "current": { "text": "All", "value": ".+" },
        "options": [
          { "selected": true, "text": "All", "value": ".+" },
          { "selected": false, "text": "production", "value": "production" },
          { "selected": false, "text": "infrastructure", "value": "infrastructure" },
          { "selected": false, "text": "development", "value": "development" }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "query": "All : .+,kamal-proxy,nadeshiko-frontend-prod-web-prod,nadeshiko-backend-prod-web-prod,nadeshiko-frontend-dev-web-dev,nadeshiko-backend-dev-web-dev,nadeshiko-backend-prod-postgres,syncthing,homeassistant,restic-backup,grafana,victorialogs",
        "current": { "text": "All", "value": ".+" },
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "host",
        "type": "custom",
        "label": "Host",
        "query": "All : .+,nadeshiko,monitoring,inari,watchtower,qtower",
        "current": { "text": "All", "value": ".+" },
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "severity",
        "type": "custom",
        "label": "Severity",
        "query": "All : .+,ERROR,WARN,INFO,DEBUG",
        "current": { "text": "All", "value": ".+" },
        "options": [
          { "selected": true, "text": "All", "value": ".+" },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "WARN", "value": "WARN" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "DEBUG", "value": "DEBUG" }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "current": { "text": "", "value": "" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Log Volume",
      "datasource": { "uid": "victorialogs" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal" },
            "barAlignment": 0,
            "barWidthFactor": 0.9
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Unspecified" }, "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-purple", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "victorialogs" },
          "expr": "{service.name=~\"${service}\", host.name=~\"${host}\", deployment.environment=~\"${environment}\"} severity:~\"${severity}\" ${search} | stats by (severity) count() logs",
          "legendFormat": "{{ severity }}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs",
      "datasource": { "uid": "victorialogs" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 6 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "victorialogs" },
          "expr": "{service.name=~\"${service}\", host.name=~\"${host}\", deployment.environment=~\"${environment}\"} severity:~\"${severity}\" ${search}",
          "maxLines": 500
        }
      ]
    }
  ]
}
