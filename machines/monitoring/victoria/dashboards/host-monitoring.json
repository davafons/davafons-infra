{
  "uid": "host-monitoring",
  "title": "Host Monitoring",
  "tags": ["infrastructure", "hosts"],
  "timezone": "browser",
  "refresh": "1m",
  "editable": false,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "VictoriaMetrics (Prometheus)", "value": "victoriametrics-prom" },
        "hide": 2
      },
      {
        "name": "environment",
        "type": "custom",
        "label": "Environment",
        "query": "All : .+,Production : nadeshiko|monitoring|inari,Non-Production : watchtower|qtower",
        "current": { "text": "All", "value": ".+" },
        "options": [
          { "selected": true, "text": "All", "value": ".+" },
          { "selected": false, "text": "Production", "value": "nadeshiko|monitoring|inari" },
          { "selected": false, "text": "Non-Production", "value": "watchtower|qtower" }
        ],
        "hide": 0
      },
      {
        "name": "host",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(system_cpu_time_seconds_total{host_name=~\"${environment}\", host_name!~\"[0-9a-f]{12}\"}, host_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "netdevice",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(system_network_io_bytes_total{host_name=~\"${host:regex}\", device!~\"veth.*|docker.*|br-.*|lo|tunl0|virbr0\"}, device)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "CPU Usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - avg by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"used\"}) / sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\"})",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Load Average (1m)",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_cpu_load_average_1m{host_name=~\"${host:regex}\"}",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Filesystem Usage (/)",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host_name) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", mountpoint=\"/\", state=\"used\"}) / (sum by (host_name) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", mountpoint=\"/\", state=\"used\"}) + sum by (host_name) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", mountpoint=\"/\", state=\"free\"}))",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - avg by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage by State",
      "description": "Stacked CPU time by state per host",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "fillOpacity": 80, "lineWidth": 0, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (host_name, state) (rate(system_cpu_time_seconds_total{host_name=~\"${host:regex}\", state!=\"idle\"}[$__rate_interval]))",
          "legendFormat": "{{ host_name }} - {{ state }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Load Average",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Load Average",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_cpu_load_average_1m{host_name=~\"${host:regex}\"}", "legendFormat": "{{ host_name }} - 1m" },
        { "refId": "B", "expr": "system_cpu_load_average_5m{host_name=~\"${host:regex}\"}", "legendFormat": "{{ host_name }} - 5m" },
        { "refId": "C", "expr": "system_cpu_load_average_15m{host_name=~\"${host:regex}\"}", "legendFormat": "{{ host_name }} - 15m" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Processes",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_processes_count{host_name=~\"${host:regex}\"}", "legendFormat": "{{ host_name }} - {{ status }}" },
        { "refId": "B", "expr": "rate(system_processes_created_total{host_name=~\"${host:regex}\"}[$__rate_interval])", "legendFormat": "{{ host_name }} - forks/s" }
      ]
    },
    {
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 60, "lineWidth": 0, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"used\"}", "legendFormat": "{{ host_name }} - used" },
        { "refId": "B", "expr": "system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"cached\"}", "legendFormat": "{{ host_name }} - cached" },
        { "refId": "C", "expr": "system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"buffered\"}", "legendFormat": "{{ host_name }} - buffered" },
        { "refId": "D", "expr": "system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"free\"}", "legendFormat": "{{ host_name }} - free" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\", state=\"used\"}) / sum by (host_name) (system_memory_usage_bytes{host_name=~\"${host:regex}\"})",
          "legendFormat": "{{ host_name }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Swap / Paging",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Swap Usage",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 40, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_paging_usage_bytes{host_name=~\"${host:regex}\", state=\"used\"}", "legendFormat": "{{ host_name }} - used" },
        { "refId": "B", "expr": "system_paging_usage_bytes{host_name=~\"${host:regex}\", state=\"free\"}", "legendFormat": "{{ host_name }} - free" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Paging Activity",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_paging_operations_total{host_name=~\"${host:regex}\"}[$__rate_interval])", "legendFormat": "{{ host_name }} - {{ type }} {{ direction }}" },
        { "refId": "B", "expr": "rate(system_paging_faults_total{host_name=~\"${host:regex}\"}[$__rate_interval])", "legendFormat": "{{ host_name }} - faults {{ type }}" }
      ]
    },
    {
      "type": "row",
      "title": "Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*transmit.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_network_io_bytes_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\", direction=\"receive\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} receive" },
        { "refId": "B", "expr": "rate(system_network_io_bytes_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\", direction=\"transmit\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} transmit" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Errors & Drops",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_network_errors_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} errors {{ direction }}" },
        { "refId": "B", "expr": "rate(system_network_dropped_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} drops {{ direction }}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Packets",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*transmit.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_network_packets_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\", direction=\"receive\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} receive" },
        { "refId": "B", "expr": "rate(system_network_packets_total{host_name=~\"${host:regex}\", device=~\"${netdevice:regex}\", direction=\"transmit\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} transmit" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Connections",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_network_connections{host_name=~\"${host:regex}\"}", "legendFormat": "{{ host_name }} {{ protocol }} {{ state }}" }
      ]
    },
    {
      "type": "row",
      "title": "Disk I/O",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Throughput",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*write.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_disk_io_bytes_total{host_name=~\"${host:regex}\", device!~\"loop.*\", direction=\"read\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} read" },
        { "refId": "B", "expr": "rate(system_disk_io_bytes_total{host_name=~\"${host:regex}\", device!~\"loop.*\", direction=\"write\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} write" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk IOPS",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*write.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_disk_operations_total{host_name=~\"${host:regex}\", device!~\"loop.*\", direction=\"read\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} read" },
        { "refId": "B", "expr": "rate(system_disk_operations_total{host_name=~\"${host:regex}\", device!~\"loop.*\", direction=\"write\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }} write" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Time",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 67 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "fillOpacity": 20, "lineWidth": 1 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "rate(system_disk_io_time_seconds_total{host_name=~\"${host:regex}\", device!~\"loop.*\"}[$__rate_interval])", "legendFormat": "{{ host_name }} {{ device }}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Avg Latency",
      "description": "Average time per I/O operation",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 67 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(system_disk_operation_time_seconds_total{host_name=~\"${host:regex}\", device!~\"loop.*\"}[$__rate_interval]) / rate(system_disk_operations_total{host_name=~\"${host:regex}\", device!~\"loop.*\"}[$__rate_interval])",
          "legendFormat": "{{ host_name }} {{ device }} {{ direction }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Filesystem",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 75 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Filesystem Space Used %",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 76 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host_name, mountpoint) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", type!~\"tmpfs|devtmpfs|squashfs|overlay\", state=\"used\"}) / (sum by (host_name, mountpoint) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", type!~\"tmpfs|devtmpfs|squashfs|overlay\", state=\"used\"}) + sum by (host_name, mountpoint) (system_filesystem_usage_bytes{host_name=~\"${host:regex}\", type!~\"tmpfs|devtmpfs|squashfs|overlay\", state=\"free\"}))",
          "legendFormat": "{{ host_name }} {{ mountpoint }}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "table",
      "title": "Filesystem Details",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 76 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "displayName", "value": "Used" }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "displayName", "value": "Free" }] }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "expr": "system_filesystem_usage_bytes{host_name=~\"${host:regex}\", type!~\"tmpfs|devtmpfs|squashfs|overlay\", state=\"used\"}", "format": "table", "instant": true },
        { "refId": "B", "expr": "system_filesystem_usage_bytes{host_name=~\"${host:regex}\", type!~\"tmpfs|devtmpfs|squashfs|overlay\", state=\"free\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "scope_name": true, "scope_name 1": true, "scope_name 2": true,
              "scope_version": true, "scope_version 1": true, "scope_version 2": true,
              "state": true, "state 1": true, "state 2": true,
              "mode": true, "mode 1": true, "mode 2": true
            }
          }
        }
      ]
    }
  ]
}
